pkgbase = pkgdrop
	pkgdesc = Universal package installer for Arch Linux
	pkgver = 3.0.0
	pkgrel = 1
	url = https://github.com/theyonecodes/pkgdrop
	arch = any
	license = MIT
	depends = bash
	optdepends = pacman: for .pkg.tar.* packages
	optdepends = debtap: for .deb packages
	optdepends = alien: for .rpm packages
	optdepends = jq: for package registry and version tracking
	optdepends = bubblewrap: for sandbox extraction
	optdepends = firejail: for sandbox extraction (alternative to bubblewrap)
	source = pkgdrop::https://raw.githubusercontent.com/theyonecodes/pkgdrop/main/src/pkgdrop
	sha256sums = SKIP

pkgname = pkgdrop
